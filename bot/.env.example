# ============ Zenox bot — .env ============
# Copie este arquivo para .env e preencha os campos vazios.

# --- Discord (obrigatório) ---
# Discord Developer Portal → seu app → Bot → Reset Token
DISCORD_TOKEN=
# Developer Portal → General Information → Application ID
DISCORD_CLIENT_ID=
# ID do servidor de testes (registra comandos instantâneo). Deixe vazio em produção global.
DISCORD_DEV_GUILD_ID=
# Seu user ID no Discord (dono do bot, comandos owner-only)
BOT_OWNER_ID=

# --- Banco (obrigatório) ---
# MongoDB connection string (Atlas: mongodb+srv://user:pass@cluster.../zenox)
MONGO_URI=

# --- Lovable Cloud / Supabase (obrigatório) ---
SUPABASE_URL=https://jfbcgpvlrkkkxmlhbvzq.supabase.co
# Service Role key — pegue no painel da Lovable Cloud (Backend → API keys)
SUPABASE_SERVICE_ROLE_KEY=

# --- Branding (opcional) ---
BRAND_NAME=Zenox
BRAND_COLOR=0x7C3AED
APP_URL=https://id-preview--e9bcc241-1f95-42ca-967d-43c879373224.lovable.app

# --- Runtime ---
NODE_ENV=production
LOG_LEVEL=info
