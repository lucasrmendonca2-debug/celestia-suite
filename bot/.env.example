# ============ Zenox bot — .env ============
# Copie este arquivo para .env e preencha os campos vazios.
# NUNCA commite o .env preenchido.

# --- Discord (obrigatório) ---
# Developer Portal → Bot → Reset Token
DISCORD_TOKEN=
# Developer Portal → General Information → Application ID
DISCORD_CLIENT_ID=
# ID do servidor de testes (registra comandos instantâneo).
# Deixe vazio em produção para registro global.
DISCORD_DEV_GUILD_ID=
# Seu user ID no Discord (dono do bot, comandos owner-only)
BOT_OWNER_ID=

# --- Supabase / Lovable Cloud (obrigatório) ---
SUPABASE_URL=
# Service Role key — pegue no painel da Lovable Cloud (Backend → API keys).
# Bypassa RLS. Mantenha SÓ no processo do bot.
SUPABASE_SERVICE_ROLE_KEY=

# --- Branding (opcional) ---
BRAND_NAME=Zenox
BRAND_COLOR=0x7C3AED
# URL pública do dashboard — usada em links e como default de CORS.
APP_URL=https://zenoxbot.lovable.app

# --- HTTP bridge (necessário para /daily web no dashboard) ---
# Porta do bridge HTTP (default 3001; sempre escuta 8080 também).
BOT_HTTP_PORT=3001
# Segredo compartilhado com o dashboard. Mesma string em ambos os lados.
BOT_API_SECRET=
# CSV de origens CORS extras. Vazio = só APP_URL é aceito.
# Use somente para domínios confiáveis (ex.: preview URL).
BOT_API_ALLOWED_ORIGINS=
# Limite de body do bridge em bytes (default 32768).
BOT_API_MAX_BODY_BYTES=32768

# --- Runtime ---
NODE_ENV=production
LOG_LEVEL=info
