# ============================================================
# Bot Discord (bot/.env) — Discord.js v14 + Supabase
# ============================================================

# ----- Discord -----
# Token do bot (BOT token, NÃO o client secret)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# (opcional) Guild para registrar comandos instantaneamente em dev
DISCORD_DEV_GUILD_ID=
BOT_OWNER_ID=

# ----- Supabase (banco principal — mesmo do dashboard) -----
SUPABASE_URL=
# Service role bypassa RLS — bot é confiável. NUNCA exponha no frontend.
SUPABASE_SERVICE_ROLE_KEY=

# ----- MongoDB (legado, em remoção) -----
# Ainda usado por Tickets, GuildConfig, VipMembership, Punishment, Giveaway,
# Reminder, Announcement. Será migrado para Supabase em fases.
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/discord_bot?retryWrites=true&w=majority

# ----- Branding -----
BRAND_NAME=Zenox
BRAND_COLOR=0x7C3AED

# ----- Runtime -----
APP_URL=http://localhost:8080
NODE_ENV=development
LOG_LEVEL=info
