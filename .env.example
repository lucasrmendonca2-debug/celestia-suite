# ============================================================
# Dashboard (.env) — TanStack Start + Lovable Cloud (Supabase)
# ============================================================
# NUNCA commite este arquivo preenchido. Use placeholders no .env.example.

# ----- Discord OAuth (login do dashboard) -----
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# URL pública do dashboard, SEM barra no fim. Dev: http://localhost:8080
APP_URL=http://localhost:8080
DISCORD_REDIRECT_URI=http://localhost:8080/api/auth/discord/callback

# Token do bot — usado pelo dashboard p/ chamadas REST do Discord
# (mesmo valor de DISCORD_TOKEN no bot)
DISCORD_BOT_TOKEN=

# ----- Sessão (gere com: openssl rand -hex 32) -----
SESSION_SECRET=

# ----- Supabase / Lovable Cloud -----
# As versões VITE_* são geradas automaticamente pelo Lovable Cloud.
# As versões abaixo são necessárias para server functions:
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# NUNCA expor no frontend. Importada apenas em handlers de server functions
# via `await import("@/lib/supabase-admin.server")`.
SUPABASE_SERVICE_ROLE_KEY=

# ----- Bridge HTTP do bot (necessária para /daily web e RPCs) -----
# URL onde o bot expõe o HTTP bridge. Sem isso, /daily web retorna `bot_not_configured`.
# Ex.: http://localhost:3001 em dev, https://bot.seu-dominio.com em prod.
BOT_API_URL=
# Mesmo valor de BOT_API_SECRET no bot/.env — usado no header `x-bot-secret`.
BOT_API_SECRET=

# ----- Admin / Owner -----
# Discord user ID do dono (owner-only commands, Premium admin page)
BOT_OWNER_ID=
# CSV de Discord IDs com acesso à página /dev-logs. Vazio = ninguém acessa.
DEV_LOG_ADMIN_IDS=

# ----- Misc -----
NODE_ENV=development
