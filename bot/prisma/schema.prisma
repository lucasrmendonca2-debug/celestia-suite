// Prisma schema — Zenox
// Run: bunx prisma migrate dev  (ou npx)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Guild & config ----------
model Guild {
  id              String   @id // discord guild id
  name            String
  prefix          String   @default("/")
  language        String   @default("pt-BR")
  premium         Boolean  @default(false)
  premiumUntil    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  config          GuildConfig?
  tickets         Ticket[]
  ticketPanels    TicketPanel[]
  punishments     Punishment[]
  warnings        Warning[]
  logs            LogEntry[]
  vips            VipMembership[]
  economy         EconomyAccount[]
  levels          LevelAccount[]
  giveaways       Giveaway[]
  suggestions     Suggestion[]
  cooldowns       Cooldown[]
}

model GuildConfig {
  guildId             String  @id
  guild               Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)

  // Channels
  modLogChannelId     String?
  messageLogChannelId String?
  memberLogChannelId  String?
  ticketLogChannelId  String?
  welcomeChannelId    String?
  goodbyeChannelId    String?
  levelUpChannelId    String?
  suggestionsChannelId String?

  // Roles
  muteRoleId          String?
  autoRoleId          String?
  supportRoleId       String?
  vipRoleId           String?

  // Welcome / Goodbye
  welcomeEnabled      Boolean @default(false)
  welcomeMessage      String  @default("Bem-vindo(a) {user} ao **{server}**! Agora somos **{memberCount}** membros 🎉")
  welcomeDmEnabled    Boolean @default(false)
  welcomeDmMessage    String?

  goodbyeEnabled      Boolean @default(false)
  goodbyeMessage      String  @default("{user} saiu do servidor. Sentiremos saudades 👋")

  // Logs toggles
  logMessageDelete    Boolean @default(true)
  logMessageEdit      Boolean @default(true)
  logMemberJoin       Boolean @default(true)
  logMemberLeave      Boolean @default(true)
  logModeration       Boolean @default(true)
  logVoice            Boolean @default(false)

  // AutoMod
  antiSpamEnabled     Boolean @default(false)
  antiLinkEnabled     Boolean @default(false)
  antiInviteEnabled   Boolean @default(false)
  antiRaidEnabled     Boolean @default(false)
  blacklistedWords    String[] @default([])

  // Economy / Level toggles
  economyEnabled      Boolean @default(true)
  levelEnabled        Boolean @default(true)
  levelMultiplier     Float   @default(1.0)
  noXpChannels        String[] @default([])

  updatedAt           DateTime @updatedAt
}

// ---------- Users (global) ----------
model User {
  id          String   @id // discord user id
  username    String?
  blacklisted Boolean  @default(false)
  blacklistReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vips        VipMembership[]
  economy     EconomyAccount[]
  levels      LevelAccount[]
  warnings    Warning[]
  punishments Punishment[]
  tickets     Ticket[]
}

// ---------- Moderation ----------
enum PunishmentType {
  BAN
  TEMPBAN
  KICK
  MUTE
  TEMPMUTE
  WARN
  UNBAN
  UNMUTE
}

model Punishment {
  id          String         @id @default(cuid())
  guildId     String
  guild       Guild          @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  moderatorId String
  type        PunishmentType
  reason      String?
  durationMs  Int?
  expiresAt   DateTime?
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())

  @@index([guildId, userId])
  @@index([active, expiresAt])
}

model Warning {
  id          String   @id @default(cuid())
  guildId     String
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  moderatorId String
  reason      String
  createdAt   DateTime @default(now())

  @@index([guildId, userId])
}

// ---------- Tickets ----------
model TicketPanel {
  id            String   @id @default(cuid())
  guildId       String
  guild         Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channelId     String
  messageId     String?
  title         String   @default("Suporte")
  description   String   @default("Clique no botão abaixo para abrir um ticket.")
  categoryId    String?  // parent category to spawn tickets under
  supportRoleId String?
  buttonLabel   String   @default("Abrir ticket")
  createdAt     DateTime @default(now())

  tickets       Ticket[]
}

enum TicketStatus {
  OPEN
  CLOSED
  DELETED
}

model Ticket {
  id          String       @id @default(cuid())
  guildId     String
  guild       Guild        @relation(fields: [guildId], references: [id], onDelete: Cascade)
  panelId     String?
  panel       TicketPanel? @relation(fields: [panelId], references: [id])
  channelId   String       @unique
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  subject     String?
  status      TicketStatus @default(OPEN)
  closedById  String?
  closedAt    DateTime?
  rating      Int?
  ratingNote  String?
  createdAt   DateTime     @default(now())

  @@index([guildId, userId])
}

// ---------- VIP / Premium ----------
enum VipTier {
  BRONZE
  SILVER
  GOLD
  DIAMOND
}

model VipMembership {
  id          String    @id @default(cuid())
  guildId     String
  guild       Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  tier        VipTier   @default(BRONZE)
  active      Boolean   @default(true)
  grantedById String
  expiresAt   DateTime? // null = vitalício
  createdAt   DateTime  @default(now())

  @@unique([guildId, userId])
  @@index([active, expiresAt])
}

// ---------- Economy ----------
model EconomyAccount {
  guildId   String
  guild     Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId    String
  user      User   @relation(fields: [userId], references: [id])
  wallet    Int    @default(0)
  bank      Int    @default(0)
  lastDaily DateTime?
  lastWork  DateTime?
  lastCrime DateTime?
  lastRob   DateTime?

  @@id([guildId, userId])
}

model ShopItem {
  id        String   @id @default(cuid())
  guildId   String
  name      String
  description String?
  price     Int
  stock     Int      @default(-1) // -1 = ilimitado
  roleId    String?
  createdAt DateTime @default(now())

  @@index([guildId])
}

model InventoryItem {
  id        String   @id @default(cuid())
  guildId   String
  userId    String
  itemId    String
  qty       Int      @default(1)
  createdAt DateTime @default(now())

  @@index([guildId, userId])
}

// ---------- Level / XP ----------
model LevelAccount {
  guildId  String
  guild    Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  xp       Int    @default(0)
  level    Int    @default(0)
  lastXpAt DateTime?

  @@id([guildId, userId])
}

model LevelReward {
  id      String @id @default(cuid())
  guildId String
  level   Int
  roleId  String

  @@unique([guildId, level])
}

// ---------- Logs ----------
model LogEntry {
  id        String   @id @default(cuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  kind      String   // "moderation" | "ticket" | "vip" | "message" | "member" | ...
  payload   Json
  createdAt DateTime @default(now())

  @@index([guildId, kind, createdAt])
}

// ---------- Giveaways ----------
model Giveaway {
  id        String   @id @default(cuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channelId String
  messageId String   @unique
  prize     String
  winners   Int      @default(1)
  endsAt    DateTime
  ended     Boolean  @default(false)
  hostId    String
  requiredRoleId String?
  participants String[] @default([])
  winnerIds String[] @default([])
  createdAt DateTime @default(now())

  @@index([ended, endsAt])
}

// ---------- Suggestions ----------
enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
  IMPLEMENTED
}

model Suggestion {
  id        String   @id @default(cuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  channelId String
  messageId String
  authorId  String
  content   String
  status    SuggestionStatus @default(PENDING)
  staffNote String?
  upvotes   Int      @default(0)
  downvotes Int      @default(0)
  createdAt DateTime @default(now())

  @@index([guildId, status])
}

// ---------- Cooldowns (per command/user/guild) ----------
model Cooldown {
  id        String   @id @default(cuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId    String
  command   String
  expiresAt DateTime

  @@unique([guildId, userId, command])
  @@index([expiresAt])
}

// ---------- Global blacklist ----------
model GlobalBlacklist {
  id        String   @id @default(cuid())
  targetId  String   @unique // user or guild id
  kind      String   // "user" | "guild"
  reason    String?
  createdAt DateTime @default(now())
}
