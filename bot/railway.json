{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node dist/index.js",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 100,
    "numReplicas": 1,
    "sleepApplication": false
  }
}
