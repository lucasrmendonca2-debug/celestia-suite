# ============ Discord ============
# Token do bot (Discord Developer Portal → Bot → Reset Token)
DISCORD_TOKEN=

# Application ID (Developer Portal → General Information)
DISCORD_CLIENT_ID=

# (Opcional) Guild ID para registrar comandos em UM servidor de teste — propaga instantâneo.
# Deixe vazio para registrar globalmente (pode levar até 1h).
DISCORD_DEV_GUILD_ID=

# Client Secret (usado pelo dashboard, NÃO pelo bot — está aqui só por conveniência se compartilhar .env)
DISCORD_CLIENT_SECRET=

# ID do dono do bot (acesso ao painel admin global)
BOT_OWNER_ID=

# ============ Database (Supabase / Postgres) ============
# Pegue em Supabase → Project Settings → Database → Connection string → URI
# Use a "Transaction" pooler para apps serverless; para o bot Node persistente prefira "Session" (porta 5432).
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres?schema=public"

# ============ Branding ============
BRAND_NAME=Zenox
BRAND_COLOR=0x7C3AED

# ============ Runtime ============
NODE_ENV=development
LOG_LEVEL=info
